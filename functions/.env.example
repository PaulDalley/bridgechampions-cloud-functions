# Copy to functions/.env and fill with real values. Do NOT commit real secrets.

# Stripe API keys
STRIPE_KEY_LIVE=sk_live_REPLACE_ME
STRIPE_KEY_DEV=sk_test_REPLACE_ME

# Stripe webhook signing secrets
STRIPE_WEBHOOK_SECRET_LIVE=whsec_REPLACE_ME
STRIPE_WEBHOOK_SECRET_DEV=whsec_REPLACE_ME
# Optional comma-separated multi-secret support during webhook rotation:
# STRIPE_WEBHOOK_SECRETS_LIVE=whsec_old,whsec_new
# STRIPE_WEBHOOK_SECRETS_DEV=whsec_old,whsec_new

# PayPal
PAYPAL_CLIENT_ID_PROD=REPLACE_ME
PAYPAL_CLIENT_SECRET_PROD=REPLACE_ME
PAYPAL_CLIENT_ID_DEV=REPLACE_ME
PAYPAL_CLIENT_SECRET_DEV=REPLACE_ME
PAYPAL_CLIENT_ID=REPLACE_ME
PAYPAL_SECRET=REPLACE_ME

# Firebase project config
FB_DATABASE_URL=https://REPLACE_ME.firebaseio.com
FB_STORAGE_BUCKET=REPLACE_ME.appspot.com
FB_API_KEY=REPLACE_ME
FB_AUTH_DOMAIN=REPLACE_ME.firebaseapp.com
FB_PROJECT_ID=REPLACE_ME

# Email (legacy/no longer required)
# GMAIL_EMAIL=REPLACE_ME
# GMAIL_PASSWORD=REPLACE_ME
